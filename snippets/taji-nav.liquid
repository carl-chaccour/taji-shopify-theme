{{ 'landing-page.css' | asset_url | stylesheet_tag }}
{{ 'landing-page.js' | asset_url | script_tag }}

<style>
  /* On inner pages nav is always cream (not transparent) */
  .taji-inner-page nav#taji-main-nav {
    background: rgba(250,248,244,0.97) !important;
    border-bottom: 1px solid var(--gold) !important;
    backdrop-filter: blur(8px) !important;
  }
  .taji-inner-page .taji-announcement-bar {
    background: var(--gold) !important;
    border-bottom: none !important;
  }
  .taji-inner-page .taji-announcement-bar p { color: var(--black) !important; }
  .taji-inner-page .nav-mobile-left .nav-hamburger,
  .taji-inner-page .nav-mobile-left .nav-icon-btn,
  .taji-inner-page .nav-right .nav-icon-btn { color: var(--black) !important; }
  .taji-inner-page .nav-logo img { filter: none !important; }
  /* Offset page content below fixed nav */
  .taji-inner-page-content { padding-top: 108px; }
  @media (max-width: 768px) {
    .taji-inner-page-content { padding-top: 100px; }
  }
</style>

<div class="taji-inner-page">

  <div class="taji-announcement-bar scrolled">
    <p>Free Shipping on Orders Over $50 &nbsp;·&nbsp; Lebanon Delivery</p>
  </div>

  <nav id="taji-main-nav" class="scrolled">
    <div class="nav-inner">

      <div class="nav-mobile-left">
        <button class="nav-hamburger" id="taji-nav-hamburger" aria-label="Open menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <a href="{{ routes.search_url }}" class="nav-icon-btn" aria-label="Search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/>
          </svg>
        </a>
      </div>

      <a href="/" class="nav-logo">
        <img src="{{ 'taji-logo.png' | asset_url }}" alt="{{ shop.name }}" />
      </a>

      <ul class="nav-links">
        {%- for link in linklists['main-menu'].links -%}
          <li><a href="{{ link.url }}" {% if link.active %}style="color:var(--gold)"{% endif %}>{{ link.title }}</a></li>
        {%- endfor -%}
      </ul>

      <div class="nav-right">
        <a href="{{ routes.search_url }}" class="nav-icon-btn nav-search-desktop" aria-label="Search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/>
          </svg>
        </a>
        <div class="nav-icons">
          <a href="{{ routes.account_url }}" class="nav-icon-btn" aria-label="My Account">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
          </a>
          <a href="{{ routes.cart_url }}" class="nav-icon-btn" aria-label="Cart">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
            </svg>
          </a>
        </div>
        <a href="{{ routes.all_products_collection_url }}" class="btn-nav">Shop Now</a>
      </div>

    </div>
  </nav>

  <div class="nav-drawer" id="taji-nav-drawer" aria-hidden="true">
    <ul class="nav-drawer-links">
      {%- for link in linklists['main-menu'].links -%}
        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
      {%- endfor -%}
    </ul>
    <div class="nav-drawer-cta">
      <a href="{{ routes.all_products_collection_url }}" class="btn-primary">Shop Now</a>
    </div>
  </div>

</div>
