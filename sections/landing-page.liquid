{{ 'landing-page.css' | asset_url | stylesheet_tag }}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Jost:wght@300;400;500;600&family=Noto+Naskh+Arabic:wght@400;700&display=swap" rel="stylesheet" />

{%- comment -%} ======= ANNOUNCEMENT BAR ======= {%- endcomment -%}
{%- comment -%} ======= LOGO SCROLL OVERLAY ======= {%- endcomment -%}
<div class="logo-scroll-overlay" id="taji-logo-scroll-overlay">
  {%- if section.settings.overlay_logo != blank -%}
    <img src="{{ section.settings.overlay_logo | image_url: width: 600 }}" alt="{{ shop.name }}" />
  {%- else -%}
    <img src="{{ 'taji-logo-alone.png' | asset_url }}" alt="{{ shop.name }}" />
  {%- endif -%}
</div>

{%- if section.settings.announcement_text != blank -%}
  <div class="taji-announcement-bar">
    <p>{{ section.settings.announcement_text | escape }}</p>
  </div>
{%- endif -%}

{%- comment -%} ======= NAVIGATION ======= {%- endcomment -%}
<nav id="taji-main-nav">
  <div class="nav-inner">

    <!-- Mobile-left: hamburger + search -->
    <div class="nav-mobile-left">
      <button class="nav-hamburger" id="taji-nav-hamburger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <a href="{{ routes.search_url }}" class="nav-icon-btn" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/>
        </svg>
      </a>
    </div>

    <!-- Logo (left on desktop, absolutely centered on mobile) -->
    <a href="{{ section.settings.nav_link_1_url | default: '/' }}" class="nav-logo">
      {%- if section.settings.nav_logo != blank -%}
        <img src="{{ section.settings.nav_logo | image_url: width: 300 }}" alt="{{ shop.name }}" />
      {%- else -%}
        <img src="{{ 'taji-logo.png' | asset_url }}" alt="{{ shop.name }}" />
      {%- endif -%}
    </a>

    <!-- Desktop nav links -->
    <ul class="nav-links">
      {%- if section.settings.nav_link_1_label != blank -%}
        <li><a href="{{ section.settings.nav_link_1_url | default: '/' }}">{{ section.settings.nav_link_1_label }}</a></li>
      {%- endif -%}
      {%- if section.settings.nav_link_2_label != blank -%}
        <li><a href="{{ section.settings.nav_link_2_url | default: '#' }}">{{ section.settings.nav_link_2_label }}</a></li>
      {%- endif -%}
      {%- if section.settings.nav_link_3_label != blank -%}
        <li><a href="{{ section.settings.nav_link_3_url | default: '#' }}">{{ section.settings.nav_link_3_label }}</a></li>
      {%- endif -%}
      {%- if section.settings.nav_link_4_label != blank -%}
        <li><a href="{{ section.settings.nav_link_4_url | default: '#' }}">{{ section.settings.nav_link_4_label }}</a></li>
      {%- endif -%}
    </ul>

    <!-- Right group -->
    <div class="nav-right">
      <!-- Search: desktop only -->
      <a href="{{ routes.search_url }}" class="nav-icon-btn nav-search-desktop" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/>
        </svg>
      </a>
      <!-- Account + cart: always visible -->
      <div class="nav-icons">
        <a href="{{ routes.account_url }}" class="nav-icon-btn" aria-label="My Account">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
        </a>
        <a href="{{ routes.cart_url }}" class="nav-icon-btn" aria-label="Cart">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
          </svg>
        </a>
      </div>
      <!-- Shop Now: desktop only -->
      <a href="{{ section.settings.nav_shop_btn_url | default: routes.all_products_collection_url }}" class="btn-nav">
        {{- section.settings.nav_shop_btn_text | default: 'Shop Now' -}}
      </a>
    </div>

  </div>
</nav>

{%- comment -%} MOBILE DRAWER {%- endcomment -%}
<div class="nav-drawer" id="taji-nav-drawer" aria-hidden="true">
  <ul class="nav-drawer-links">
    {%- if section.settings.nav_link_1_label != blank -%}
      <li><a href="{{ section.settings.nav_link_1_url | default: '/' }}">{{ section.settings.nav_link_1_label }}</a></li>
    {%- endif -%}
    {%- if section.settings.nav_link_2_label != blank -%}
      <li><a href="{{ section.settings.nav_link_2_url | default: '#' }}">{{ section.settings.nav_link_2_label }}</a></li>
    {%- endif -%}
    {%- if section.settings.nav_link_3_label != blank -%}
      <li><a href="{{ section.settings.nav_link_3_url | default: '#' }}">{{ section.settings.nav_link_3_label }}</a></li>
    {%- endif -%}
    {%- if section.settings.nav_link_4_label != blank -%}
      <li><a href="{{ section.settings.nav_link_4_url | default: '#' }}">{{ section.settings.nav_link_4_label }}</a></li>
    {%- endif -%}
  </ul>
  <div class="nav-drawer-cta">
    <a href="{{ section.settings.nav_shop_btn_url | default: routes.all_products_collection_url }}" class="btn-primary">
      {{- section.settings.nav_shop_btn_text | default: 'Shop Now' -}}
    </a>
  </div>
</div>

{%- comment -%} ======= HERO ======= {%- endcomment -%}
<section class="hero">
  <div class="hero-bg-motif" aria-hidden="true">تاجي</div>
  <div class="hero-inner">
    <div>
      {%- if section.settings.hero_eyebrow != blank -%}
        <p class="hero-eyebrow">{{ section.settings.hero_eyebrow | escape }}</p>
      {%- endif -%}
      <h1 class="hero-headline serif">
        {{ section.settings.hero_headline_line1 | escape }}<br />
        <span>{{ section.settings.hero_headline_italic | escape }}</span>
      </h1>
      {%- if section.settings.hero_subhead != blank -%}
        <p class="hero-subhead">{{ section.settings.hero_subhead | escape }}</p>
      {%- endif -%}
      {%- if section.settings.hero_arabic != blank -%}
        <p class="hero-arabic">{{ section.settings.hero_arabic | escape }}</p>
      {%- endif -%}
      <div class="hero-cta-wrap">
        <a href="{{ section.settings.hero_cta_url | default: routes.all_products_collection_url }}" class="btn-primary">
          {{- section.settings.hero_cta_text | default: 'Crown Yourself →' -}}
        </a>
      </div>
      {%- if section.settings.hero_shipping_text != blank -%}
        <p class="hero-shipping">{{ section.settings.hero_shipping_text | escape }}</p>
      {%- endif -%}
    </div>
    <div class="hero-image-wrap">
      <div style="position:relative; overflow:visible;">
        {%- if section.settings.hero_image != blank -%}
          <img
            src="{{ section.settings.hero_image | image_url: width: 800 }}"
            alt="{{ section.settings.hero_image.alt | default: 'Woman wearing TAJI crown' }}"
            style="width:100%; border-radius:2px; display:block;"
            loading="eager"
          />
        {%- else -%}
          <img src="{{ 'hero-woman.png' | asset_url }}" alt="Woman wearing TAJI crown" style="width:100%; border-radius:2px; display:block;" />
        {%- endif -%}
        <div class="hero-callout">
          {%- if section.settings.hero_callout_image != blank -%}
            <img
              src="{{ section.settings.hero_callout_image | image_url: width: 120 }}"
              alt="{{ section.settings.hero_callout_image.alt | default: 'Crown detail' }}"
            />
          {%- else -%}
            <img src="{{ 'product-inside.png' | asset_url }}" alt="Rubber crown under hijab" />
          {%- endif -%}
          <div>
            <p class="hero-callout-label">{{ section.settings.hero_callout_label | default: 'Hidden inside' | escape }}</p>
            <p class="hero-callout-text">{{ section.settings.hero_callout_text | default: 'The rubber grip crown — invisible, unshakeable.' | escape }}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{%- comment -%} ======= TRUST BAR ======= {%- endcomment -%}
{%- assign trust_items = section.blocks | where: 'type', 'trust_item' -%}
{%- if trust_items.size > 0 -%}
  <div class="trust-bar">
    <div class="trust-bar-inner">
      {%- for block in trust_items -%}
        <div class="trust-item" {{ block.shopify_attributes }}>
          <span class="trust-icon" aria-hidden="true">✦</span>
          <span>{{ block.settings.label | escape }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{%- comment -%} ======= PRODUCT SECTION ======= {%- endcomment -%}
{%- assign product_bullets = section.blocks | where: 'type', 'product_bullet' -%}
<section class="section section-cream" id="product">
  <div class="section-inner">
    <div class="product-split">
      <div class="product-images">
        <div class="product-img-col">
          {%- if section.settings.product_image1 != blank -%}
            <img
              src="{{ section.settings.product_image1 | image_url: width: 600 }}"
              alt="{{ section.settings.product_image1.alt | default: 'TAJI Packaging' }}"
            />
          {%- else -%}
            <img src="{{ 'package-nobg.png' | asset_url }}" alt="TAJI Packaging" />
          {%- endif -%}
          <p class="product-img-label">{{ section.settings.product_image1_label | default: 'The Package' | escape }}</p>
        </div>
        <div class="product-divider"></div>
        <div class="product-img-col rubber">
          {%- if section.settings.product_image2 != blank -%}
            <img
              src="{{ section.settings.product_image2 | image_url: width: 600 }}"
              alt="{{ section.settings.product_image2.alt | default: 'TAJI Crown' }}"
            />
          {%- else -%}
            <img src="{{ 'rubber-nobg.png' | asset_url }}" alt="TAJI Rubber Crown" />
          {%- endif -%}
          <p class="product-img-label">{{ section.settings.product_image2_label | default: 'The Crown' | escape }}</p>
        </div>
      </div>
      <div>
        {%- if section.settings.product_eyebrow != blank -%}
          <p class="section-eyebrow" style="text-align:left;">{{ section.settings.product_eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.product_headline != blank -%}
          <h2 class="section-headline serif" style="text-align:left; margin-bottom:24px;">{{ section.settings.product_headline | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.product_body != blank -%}
          <p class="product-body">{{ section.settings.product_body | escape }}</p>
        {%- endif -%}
        {%- if product_bullets.size > 0 -%}
          <ul class="product-bullets">
            {%- for block in product_bullets -%}
              <li {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
        <a href="{{ section.settings.product_shop_url | default: routes.all_products_collection_url }}" class="btn-primary">
          {{- section.settings.product_shop_text | default: 'Shop The Crown' -}}
        </a>
      </div>
    </div>
  </div>
</section>

{%- comment -%} ======= PROBLEM SECTION ======= {%- endcomment -%}
{%- assign pain_cards = section.blocks | where: 'type', 'pain_card' -%}
<section class="section section-white" id="problem">
  <div class="section-inner">
    {%- if section.settings.problem_eyebrow != blank -%}
      <p class="section-eyebrow">{{ section.settings.problem_eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.problem_headline != blank -%}
      <h2 class="section-headline serif">{{ section.settings.problem_headline | escape }}</h2>
    {%- endif -%}
    {%- if pain_cards.size > 0 -%}
      <div class="pain-grid">
        {%- for block in pain_cards -%}
          <div class="pain-card" {{ block.shopify_attributes }}>
            <div class="pain-icon" aria-hidden="true">◆</div>
            <p class="pain-text">{{ block.settings.text | escape }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
    {%- if section.settings.problem_divider_text != blank -%}
      <div style="text-align:center;">
        <div class="section-divider">
          <div class="gold-rule"></div>
          <span style="font-size:11px; letter-spacing:0.2em; color:var(--gold); white-space:nowrap; font-weight:500;">
            {{- section.settings.problem_divider_text | escape -}}
          </span>
          <div class="gold-rule"></div>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{%- comment -%} ======= QURAN VERSE GIFT ======= {%- endcomment -%}
<style>
  .taji-quran-section {
    background: var(--black);
    padding: 100px 32px;
    position: relative;
    overflow: hidden;
    text-align: center;
  }
  .taji-quran-watermark {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Noto Naskh Arabic', serif;
    font-size: 360px;
    color: var(--gold);
    opacity: 0.04;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
    z-index: 0;
    line-height: 1;
  }
  .taji-quran-inner {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    text-align: left;
  }
  .taji-quran-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 24px;
  }
  .taji-quran-badge span {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--gold);
    opacity: 0.5;
  }
  .taji-quran-headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 300;
    letter-spacing: 0.06em;
    color: white;
    line-height: 1.25;
    margin-bottom: 20px;
  }
  .taji-quran-body {
    font-size: 15px;
    font-weight: 300;
    line-height: 1.9;
    color: rgba(255,255,255,0.65);
    margin-bottom: 28px;
  }
  .taji-quran-tag {
    display: inline-block;
    border: 1px solid rgba(212,179,111,0.35);
    padding: 8px 20px;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    border-radius: 2px;
  }
  .taji-quran-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .taji-quran-paper {
    background: #f5ead8;
    border-radius: 4px;
    padding: 36px 32px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5), inset 0 0 40px rgba(0,0,0,0.08);
    transform: rotate(-2deg);
    max-width: 320px;
    width: 100%;
    text-align: right;
    position: relative;
  }
  .taji-quran-paper::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 4px;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 27px,
      rgba(139,109,56,0.12) 27px,
      rgba(139,109,56,0.12) 28px
    );
    pointer-events: none;
  }
  .taji-quran-paper-label {
    font-family: 'Jost', sans-serif;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #a0856a;
    font-weight: 600;
    margin-bottom: 16px;
    text-align: left;
  }
  .taji-quran-arabic-text {
    font-family: 'Noto Naskh Arabic', serif;
    font-size: 22px;
    line-height: 2;
    color: #3d2b1a;
    direction: rtl;
    margin-bottom: 16px;
  }
  .taji-quran-translation {
    font-family: 'Cormorant Garamond', serif;
    font-size: 13px;
    font-style: italic;
    color: #7a5c3e;
    line-height: 1.7;
    text-align: left;
    border-top: 1px solid rgba(139,109,56,0.2);
    padding-top: 12px;
    margin-top: 4px;
  }
  .taji-quran-surah {
    font-family: 'Jost', sans-serif;
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #a0856a;
    font-weight: 600;
    margin-top: 10px;
    text-align: left;
  }
  @media (max-width: 768px) {
    .taji-quran-inner { grid-template-columns: 1fr; gap: 48px; text-align: center; }
    .taji-quran-paper { transform: rotate(-1deg); margin: 0 auto; }
    .taji-quran-section { padding: 72px 24px; }
    .taji-quran-watermark { font-size: 160px; }
  }
</style>

<section class="taji-quran-section">
  <div class="taji-quran-watermark" aria-hidden="true">تاجي</div>
  <div class="taji-quran-inner">

    <div>
      <div class="taji-quran-badge">
        <span></span>
        {{ section.settings.quran_eyebrow | default: 'A Gift Inside Every Package' | escape }}
        <span></span>
      </div>
      <h2 class="taji-quran-headline serif">{{ section.settings.quran_headline | default: 'A Verse That Travels With You.' | escape }}</h2>
      <p class="taji-quran-body">{{ section.settings.quran_body | default: 'Every TAJI crown arrives with a hand-selected Quran verse printed on authentic papyrus paper. A reminder of grace, confidence, and purpose — tucked inside every order.' | escape }}</p>
      <span class="taji-quran-tag">{{ section.settings.quran_tag | default: '✦ Exclusive to TAJI' | escape }}</span>
    </div>

    <div class="taji-quran-visual">
      {%- if section.settings.quran_image != blank -%}
        <img
          src="{{ section.settings.quran_image | image_url: width: 600 }}"
          alt="{{ section.settings.quran_image.alt | default: 'Quran verse on papyrus' }}"
          style="max-width:320px; width:100%; border-radius:4px; box-shadow:0 20px 60px rgba(0,0,0,0.5); transform:rotate(-2deg);"
          loading="lazy"
        />
      {%- else -%}
        <div class="taji-quran-paper">
          <p class="taji-quran-paper-label">{{ section.settings.quran_paper_label | default: 'Your TAJI Gift' | escape }}</p>
          <p class="taji-quran-arabic-text">{{ section.settings.quran_arabic | default: 'وَلَقَدْ كَرَّمْنَا بَنِي آدَمَ' | escape }}</p>
          <p class="taji-quran-translation">{{ section.settings.quran_translation | default: '"And We have certainly honoured the children of Adam."' | escape }}</p>
          <p class="taji-quran-surah">{{ section.settings.quran_surah | default: '— Surah Al-Isra, 17:70' | escape }}</p>
        </div>
      {%- endif -%}
    </div>

  </div>
</section>

{%- comment -%} ======= HOW IT WORKS ======= {%- endcomment -%}
{%- assign steps = section.blocks | where: 'type', 'step' -%}
<section class="section section-white" id="how-it-works">
  <div class="section-inner">
    {%- if section.settings.steps_eyebrow != blank -%}
      <p class="section-eyebrow">{{ section.settings.steps_eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.steps_headline != blank -%}
      <h2 class="section-headline serif">{{ section.settings.steps_headline | escape }}</h2>
    {%- endif -%}
    {%- if steps.size > 0 -%}
      <div class="steps-grid">
        {%- for block in steps -%}
          <div class="step-item" {{ block.shopify_attributes }}>
            <div class="step-number serif">{{ block.settings.number | escape }}</div>
            <h3 class="step-name serif">{{ block.settings.name | escape }}</h3>
            <p class="step-desc">{{ block.settings.desc | escape }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{%- comment -%} ======= STORIES WIDGET ======= {%- endcomment -%}
{%- assign story_cards = section.blocks | where: 'type', 'story_card' -%}
<section class="stories-section" id="stories">
  <div class="stories-inner">
    {%- if section.settings.stories_eyebrow != blank -%}
      <p class="section-eyebrow" style="text-align:center; margin-bottom:12px;">{{ section.settings.stories_eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.stories_headline != blank -%}
      <h2 class="section-headline serif" style="margin-bottom:40px;">{{ section.settings.stories_headline | escape }}</h2>
    {%- endif -%}
    {%- if story_cards.size > 0 -%}
      <div class="stories-row">
        {%- for block in story_cards -%}
          <div
            class="story-card"
            style="background: {{ block.settings.bg_color | default: '#0d0d0d' }};"
            {{ block.shopify_attributes }}
          >
            <div class="story-ring"></div>
            <div class="story-progress"><div class="story-progress-bar"></div></div>
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 400 }}"
                alt="{{ block.settings.image.alt | default: block.settings.label }}"
                class="story-thumb"
                loading="lazy"
              />
            {%- else -%}
              <img src="{{ 'product-top.png' | asset_url }}" alt="{{ block.settings.label | escape }}" class="story-thumb" />
            {%- endif -%}
            <div class="story-gradient"></div>
            <div class="story-play-btn"><div class="story-play-icon"></div></div>
            <div class="story-label">
              <span class="story-label-text">{{ block.settings.label | escape }}</span>
              <span class="story-label-sub">{{ block.settings.sublabel | escape }}</span>
            </div>
            <div class="story-mute-badge" aria-hidden="true">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="2" stroke-linecap="round">
                <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>
              </svg>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
    {%- if section.settings.stories_hint != blank -%}
      <p class="stories-hint">{{ section.settings.stories_hint | escape }}</p>
    {%- endif -%}
  </div>
</section>

{%- comment -%} ======= REVIEWS ======= {%- endcomment -%}
{%- assign reviews = section.blocks | where: 'type', 'review' -%}
<section class="section section-cream-alt" id="reviews">
  <div class="section-inner">
    {%- if section.settings.reviews_eyebrow != blank -%}
      <p class="section-eyebrow">{{ section.settings.reviews_eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.reviews_headline != blank -%}
      <h2 class="section-headline serif">{{ section.settings.reviews_headline | escape }}</h2>
    {%- endif -%}
    {%- if reviews.size > 0 -%}
      <div class="reviews-grid">
        {%- for block in reviews -%}
          <div class="review-card" {{ block.shopify_attributes }}>
            <div class="review-quote-mark serif" aria-hidden="true">"</div>
            <p class="review-text">{{ block.settings.text | escape }}</p>
            <div class="review-stars" aria-label="5 stars">{{ block.settings.stars | default: '★★★★★' | escape }}</div>
            <p class="review-author">{{ block.settings.author | escape }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{%- comment -%} ======= VARIANTS / COLLECTION ======= {%- endcomment -%}
{%- assign variants = section.blocks | where: 'type', 'variant' -%}
<section class="section section-white" id="collection">
  <div class="section-inner">
    {%- if section.settings.variants_eyebrow != blank -%}
      <p class="section-eyebrow">{{ section.settings.variants_eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.variants_headline != blank -%}
      <h2 class="section-headline serif">{{ section.settings.variants_headline | escape }}</h2>
    {%- endif -%}
    {%- if variants.size > 0 -%}
      <div class="variants-grid">
        {%- for block in variants -%}
          {%- assign variant_product = block.settings.product -%}
          <div class="variant-card" {{ block.shopify_attributes }}>
            <div class="variant-img-box">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 500 }}"
                  alt="{{ block.settings.image.alt | default: block.settings.name }}"
                  loading="lazy"
                />
              {%- elsif variant_product != blank and variant_product.featured_image != blank -%}
                <img
                  src="{{ variant_product.featured_image | image_url: width: 500 }}"
                  alt="{{ variant_product.title }}"
                  loading="lazy"
                />
              {%- else -%}
                <img src="{{ 'product-top.png' | asset_url }}" alt="{{ block.settings.name | escape }}" />
              {%- endif -%}
            </div>
            <p class="variant-label">{{ block.settings.label | escape }}</p>
            <h3 class="variant-name serif">{{ block.settings.name | escape }}</h3>
            <p class="variant-material">{{ block.settings.material | escape }}</p>
            <p class="variant-desc">{{ block.settings.desc | escape }}</p>

            {%- if variant_product != blank -%}
              {%- assign first_variant = variant_product.selected_or_first_available_variant -%}
              {%- form 'product', variant_product, class: 'variant-form' -%}
                <input type="hidden" name="id" value="{{ first_variant.id }}" />
                <input type="hidden" name="quantity" value="1" />
                <button type="submit" class="btn-secondary">
                  {{- block.settings.button_text | default: 'Add to Cart' -}}
                </button>
              {%- endform -%}
            {%- else -%}
              {%- if request.design_mode -%}
                <p class="variant-no-product">No product selected — assign one in the theme editor</p>
              {%- endif -%}
              <button type="button" class="btn-secondary" disabled>
                {{- block.settings.button_text | default: 'Add to Cart' -}}
              </button>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{%- comment -%} ======= BRAND STORY ======= {%- endcomment -%}
<div class="brand-story" id="brand-story">
  <div class="brand-story-watermark" aria-hidden="true">تاجي</div>
  <div class="brand-story-inner">
    <div style="margin-bottom:32px;">
      {%- if section.settings.brand_story_logo != blank -%}
        <img
          src="{{ section.settings.brand_story_logo | image_url: width: 300 }}"
          alt="{{ section.settings.brand_story_logo.alt | default: 'Crown Yourself' }}"
          style="height:48px; opacity:0.85;"
        />
      {%- else -%}
        <img src="{{ 'crown-yourself.png' | asset_url }}" alt="Crown Yourself" style="height:48px; opacity:0.85;" />
      {%- endif -%}
    </div>
    {%- if section.settings.brand_story_headline != blank -%}
      <h2 class="brand-story-headline serif">{{ section.settings.brand_story_headline | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.brand_story_body != blank -%}
      <p class="brand-story-body">{{ section.settings.brand_story_body | escape }}</p>
    {%- endif -%}
  </div>
</div>

{%- comment -%} ======= FINAL CTA ======= {%- endcomment -%}
{%- assign cta_product = section.settings.cta_product -%}
<div class="final-cta" id="cta">
  {%- if section.settings.cta_eyebrow != blank -%}
    <p class="section-eyebrow">{{ section.settings.cta_eyebrow | escape }}</p>
  {%- endif -%}
  {%- if section.settings.cta_headline != blank -%}
    <h2 class="final-cta-headline serif">{{ section.settings.cta_headline | escape }}</h2>
  {%- endif -%}
  {%- if section.settings.cta_sub != blank -%}
    <p class="final-cta-sub">{{ section.settings.cta_sub | escape }}</p>
  {%- endif -%}

  {%- if cta_product != blank -%}
    {%- assign cta_variant = cta_product.selected_or_first_available_variant -%}
    {%- form 'product', cta_product, class: 'final-cta-form' -%}
      <input type="hidden" name="id" value="{{ cta_variant.id }}" />
      <input type="hidden" name="quantity" value="1" />
      <button type="submit" class="btn-primary final-cta-btn">
        {{- section.settings.cta_button_text | default: 'Shop Now' -}}
      </button>
    {%- endform -%}
  {%- else -%}
    {%- if request.design_mode -%}
      <p class="variant-no-product">No product selected — assign one in the theme editor</p>
    {%- endif -%}
    <a
      href="{{ section.settings.cta_fallback_url | default: routes.all_products_collection_url }}"
      class="btn-primary final-cta-btn"
    >
      {{- section.settings.cta_button_text | default: 'Shop Now' -}}
    </a>
  {%- endif -%}

  {%- if section.settings.cta_fine != blank -%}
    <p class="final-cta-fine">{{ section.settings.cta_fine | escape }}</p>
  {%- endif -%}
</div>

{%- comment -%} ======= FOOTER ======= {%- endcomment -%}
<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div>
        {%- if section.settings.nav_logo != blank -%}
          <img
            src="{{ section.settings.nav_logo | image_url: width: 300 }}"
            alt="{{ shop.name }}"
            class="footer-logo"
          />
        {%- else -%}
          <img src="{{ 'taji-logo.png' | asset_url }}" alt="{{ shop.name }}" class="footer-logo" />
        {%- endif -%}
        {%- if section.settings.footer_arabic != blank -%}
          <p class="footer-brand-arabic">{{ section.settings.footer_arabic | escape }}</p>
        {%- endif -%}
        {%- if section.settings.footer_tagline != blank -%}
          <p class="footer-brand-tagline">{{ section.settings.footer_tagline | escape }}</p>
        {%- endif -%}
      </div>
      <div>
        <p class="footer-col-title">{{ section.settings.footer_links_title | default: 'Quick Links' | escape }}</p>
        <ul class="footer-col-links">
          {%- if section.settings.nav_link_1_label != blank -%}
            <li><a href="{{ section.settings.nav_link_1_url | default: '/' }}">{{ section.settings.nav_link_1_label | escape }}</a></li>
          {%- endif -%}
          {%- if section.settings.nav_link_2_label != blank -%}
            <li><a href="{{ section.settings.nav_link_2_url | default: '#' }}">{{ section.settings.nav_link_2_label | escape }}</a></li>
          {%- endif -%}
          {%- if section.settings.nav_link_3_label != blank -%}
            <li><a href="{{ section.settings.nav_link_3_url | default: '#' }}">{{ section.settings.nav_link_3_label | escape }}</a></li>
          {%- endif -%}
          {%- if section.settings.nav_link_4_label != blank -%}
            <li><a href="{{ section.settings.nav_link_4_url | default: '#' }}">{{ section.settings.nav_link_4_label | escape }}</a></li>
          {%- endif -%}
          {%- if section.settings.nav_shop_btn_text != blank -%}
            <li><a href="{{ section.settings.nav_shop_btn_url | default: routes.all_products_collection_url }}">{{ section.settings.nav_shop_btn_text | escape }}</a></li>
          {%- endif -%}
