{{ 'landing-page.css' | asset_url | stylesheet_tag }}

<style>
  :root {
    --gold: #D4B36F;
    --black: #0A0A0A;
    --white: #FFFFFF;
    --cream: #FAF8F4;
    --cream-alt: #F2EDE6;
  }

  .taji-contact { background: var(--cream); font-family: 'Jost', sans-serif; }

  /* HERO */
  .contact-hero {
    background: var(--cream-alt);
    padding: 160px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .contact-hero-watermark {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Noto Naskh Arabic', serif;
    font-size: 300px;
    color: var(--gold);
    opacity: 0.05;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
    z-index: 0;
    line-height: 1;
  }
  .contact-hero-inner { position: relative; z-index: 1; max-width: 620px; margin: 0 auto; }
  .contact-eyebrow {
    font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--gold); font-weight: 600; margin-bottom: 16px;
  }
  .contact-headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 300; letter-spacing: 0.08em;
    color: var(--black); margin-bottom: 20px; line-height: 1.1;
  }
  .contact-subhead {
    font-size: 16px; font-weight: 300; line-height: 1.8;
    color: #555;
  }

  /* BODY */
  .contact-body {
    padding: 80px 32px 100px;
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 80px;
    align-items: start;
  }

  /* INFO COLUMN */
  .contact-info-label {
    font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold); font-weight: 600; margin-bottom: 32px;
  }
  .contact-info-item {
    display: flex; align-items: flex-start; gap: 16px;
    margin-bottom: 28px;
  }
  .contact-info-icon {
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--cream-alt);
    border: 1px solid rgba(212,179,111,0.3);
    display: flex; align-items: center; justify-content: center;
    color: var(--gold); font-size: 16px; flex-shrink: 0;
  }
  .contact-info-text-label {
    font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--gold); font-weight: 600; margin-bottom: 4px;
  }
  .contact-info-text a, .contact-info-text p {
    font-size: 14px; font-weight: 400; color: #444;
    text-decoration: none; line-height: 1.6;
    transition: color 0.2s;
  }
  .contact-info-text a:hover { color: var(--gold); }

  /* WHATSAPP BUTTON */
  .contact-whatsapp {
    display: inline-flex; align-items: center; gap: 14px;
    background: var(--gold);
    color: var(--black);
    padding: 16px 28px;
    border-radius: 2px;
    text-decoration: none;
    font-family: 'Jost', sans-serif;
    font-size: 13px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase;
    transition: background 0.25s ease, transform 0.2s ease;
    margin-top: 40px;
  }
  .contact-whatsapp:hover { background: #c4a35f; transform: translateY(-1px); }
  .contact-whatsapp svg { flex-shrink: 0; }
  .contact-whatsapp-note {
    font-size: 11px; letter-spacing: 0.08em; color: #888;
    margin-top: 12px;
  }

  .contact-divider {
    height: 1px; background: rgba(212,179,111,0.25);
    margin: 36px 0;
  }

  /* FORM */
  .contact-form-label {
    font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold); font-weight: 600; margin-bottom: 32px;
  }
  .contact-form .field {
    margin-bottom: 24px;
    position: relative;
  }
  .contact-form label {
    display: none;
  }
  .contact-form input,
  .contact-form textarea,
  .contact-form select {
    width: 100%;
    padding: 16px 20px;
    border: 1px solid rgba(10,10,10,0.14);
    background: #fff;
    font-family: 'Jost', sans-serif;
    font-size: 14px; font-weight: 300; color: var(--black);
    outline: none;
    transition: border-color 0.25s;
    border-radius: 0;
    appearance: none;
    box-sizing: border-box;
    text-align: center;
  }
  .contact-form input:focus,
  .contact-form textarea:focus,
  .contact-form select:focus { border-color: var(--gold); }
  .contact-form input::placeholder,
  .contact-form textarea::placeholder { color: #aaa; font-weight: 300; font-size: 13px; letter-spacing: 0.06em; text-align: center; }
  .contact-form textarea { min-height: 130px; resize: none; text-align: left; }
  .contact-form textarea::placeholder { text-align: left; }
  .contact-form .btn-primary { border: none; cursor: pointer; font-size: 12px; width: 100%; text-align: center; margin-top: 12px; }
  .contact-phone-wrap { display: flex; gap: 8px; position: relative; }
  .contact-phone-wrap input { flex: 1; }
  .taji-country-select { position: relative; flex-shrink: 0; width: 130px; }
  .taji-country-btn {
    display: flex; align-items: center; gap: 8px;
    width: 100%; height: 100%;
    padding: 0 12px;
    border: 1px solid rgba(10,10,10,0.14);
    background: #fff;
    font-family: 'Jost', sans-serif;
    font-size: 14px; font-weight: 300; color: var(--black);
    cursor: pointer; box-sizing: border-box;
    white-space: nowrap; overflow: hidden;
    justify-content: space-between;
  }
  .taji-country-btn:focus { border-color: var(--gold); outline: none; }
  .taji-country-btn .taji-flag { font-size: 18px; line-height: 1; }
  .taji-country-btn .taji-code { font-size: 13px; }
  .taji-country-btn .taji-chevron { font-size: 10px; color: #999; margin-left: 4px; }
  .taji-country-dropdown {
    display: none; position: absolute; top: 100%; left: 0;
    width: 260px; max-height: 240px; overflow-y: auto;
    background: #fff; border: 1px solid rgba(10,10,10,0.14);
    border-top: none; z-index: 999;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }
  .taji-country-dropdown.open { display: block; }
  .taji-country-search {
    width: 100%; padding: 10px 14px; border: none;
    border-bottom: 1px solid rgba(10,10,10,0.1);
    font-family: 'Jost', sans-serif; font-size: 13px;
    outline: none; box-sizing: border-box; text-align: left;
  }
  .taji-country-option {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 14px; cursor: pointer;
    font-size: 13px; font-family: 'Jost', sans-serif;
    transition: background 0.15s;
  }
  .taji-country-option:hover { background: rgba(212,179,111,0.1); }
  .taji-country-option .taji-flag { font-size: 18px; }
  .taji-country-option.selected { background: rgba(212,179,111,0.15); font-weight: 500; }

  @media (max-width: 768px) {
    .contact-hero { padding: 120px 24px 64px; }
    .contact-hero-watermark { font-size: 140px; }
    .contact-body { grid-template-columns: 1fr; gap: 56px; padding: 56px 24px 80px; }
  }
</style>

<div class="taji-contact">
<div class="taji-inner-page-content">

  <!-- HERO -->
  <div class="contact-hero">
    <div class="contact-hero-watermark" aria-hidden="true">تاجي</div>
    <div class="contact-hero-inner">
      <p class="contact-eyebrow">{{ section.settings.eyebrow | default: 'Contact Us' | escape }}</p>
      <h1 class="contact-headline serif">{{ section.settings.headline | default: 'Get in Touch' | escape }}</h1>
      <p class="contact-subhead">{{ section.settings.subhead | default: "A question, a collaboration, or just want to say hello — we'd love to hear from you." | escape }}</p>
    </div>
  </div>

  <!-- BODY -->
  <div class="contact-body">

    <!-- INFO COLUMN -->
    <div>
      <p class="contact-info-label">{{ section.settings.info_label | default: 'Ways to reach us' | escape }}</p>

      {%- if section.settings.email != blank -%}
        <div class="contact-info-item">
          <div class="contact-info-icon" aria-hidden="true">✉</div>
          <div>
            <p class="contact-info-text-label">Email</p>
            <div class="contact-info-text">
              <a href="mailto:{{ section.settings.email }}">{{ section.settings.email | escape }}</a>
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.instagram_url != blank -%}
        <div class="contact-info-item">
          <div class="contact-info-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </div>
          <div>
            <p class="contact-info-text-label">Instagram</p>
            <div class="contact-info-text">
              <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener">{{ section.settings.instagram_label | default: '@tajilb' | escape }}</a>
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.location != blank -%}
        <div class="contact-info-item">
          <div class="contact-info-icon" aria-hidden="true">◎</div>
          <div>
            <p class="contact-info-text-label">Location</p>
            <div class="contact-info-text">
              <p>{{ section.settings.location | escape }}</p>
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.response_time != blank -%}
        <div class="contact-info-item">
          <div class="contact-info-icon" aria-hidden="true">◷</div>
          <div>
            <p class="contact-info-text-label">Response time</p>
            <div class="contact-info-text">
              <p>{{ section.settings.response_time | escape }}</p>
            </div>
          </div>
        </div>
      {%- endif -%}

      <div class="contact-divider"></div>

      {%- if section.settings.whatsapp_number != blank -%}
        {%- assign wa_number = section.settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' -%}
        <a
          href="https://wa.me/{{ wa_number }}"
          class="contact-whatsapp"
          target="_blank"
          rel="noopener"
          aria-label="Chat on WhatsApp"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {{ section.settings.whatsapp_label | default: 'Chat on WhatsApp' | escape }}
        </a>
        <p class="contact-whatsapp-note">{{ section.settings.whatsapp_note | default: 'Typically replies within a few hours' | escape }}</p>
      {%- endif -%}
    </div>

    <!-- FORM COLUMN -->
    <div>
      <p class="contact-form-label">{{ section.settings.form_label | default: 'Send us a message' | escape }}</p>
      {%- form 'contact', class: 'contact-form' -%}
        {%- if form.posted_successfully? -%}
          <div style="padding: 20px; background: #f0fdf4; border: 1px solid #86efac; margin-bottom: 24px; font-size: 14px; color: #166534;">
            ✓ {{ section.settings.form_success | default: "Thank you! We'll be in touch within 24 hours." | escape }}
          </div>
        {%- endif -%}
        {%- if form.errors -%}
          <div style="padding: 20px; background: #fef2f2; border: 1px solid #fca5a5; margin-bottom: 24px; font-size: 14px; color: #991b1b;">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}
        <div class="field">
          <label for="ContactName">{{ section.settings.field_name | default: 'Your Name' | escape }}</label>
          <input type="text" id="ContactName" name="contact[name]" autocomplete="name" value="{{ form.name }}" placeholder="Your Name" required />
        </div>
        <div class="field">
          <label for="ContactEmail">{{ section.settings.field_email | default: 'Email Address' | escape }}</label>
          <input type="email" id="ContactEmail" name="contact[email]" autocomplete="email" value="{{ form.email }}" placeholder="Email Address" required />
        </div>
