<script>
(function() {
  document.addEventListener('DOMContentLoaded', function() {
    var hiddenSelect = document.querySelector('select[name="contact[phone_code_raw]"]');
    if (!hiddenSelect) return;

    var countries = [];
    hiddenSelect.querySelectorAll('option').forEach(function(opt) {
      var text = opt.textContent.trim();
      var parts = text.match(/^(\S+)\s+(.+)$/);
      if (parts) {
        countries.push({ flag: parts[1], code: parts[2], value: opt.value, name: text });
      }
    });

    var btn = document.getElementById('taji-country-btn');
    var dropdown = document.getElementById('taji-country-dropdown');
    var search = document.getElementById('taji-country-search');
    var list = document.getElementById('taji-country-list');
    var hiddenVal = document.getElementById('taji-phone-code-val');

    function renderList(filter) {
      list.innerHTML = '';
      var filtered = filter ? countries.filter(function(c) {
        return c.name.toLowerCase().includes(filter.toLowerCase());
      }) : countries;
      filtered.forEach(function(c) {
        var div = document.createElement('div');
        div.className = 'taji-country-option' + (c.value === hiddenVal.value ? ' selected' : '');
        div.setAttribute('role', 'option');
        div.innerHTML = '<span class="taji-flag">' + c.flag + '</span><span>' + c.code + '</span>';
        div.addEventListener('click', function() {
          hiddenVal.value = c.value;
          btn.querySelector('.taji-flag').textContent = c.flag;
          btn.querySelector('.taji-code').textContent = c.code;
          dropdown.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
        });
        list.appendChild(div);
      });
    }

    renderList('');

    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var open = dropdown.classList.toggle('open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      if (open) { search.value = ''; renderList(''); search.focus(); }
    });

    search.addEventListener('input', function() { renderList(this.value); });

    document.addEventListener('click', function() {
      dropdown.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    });

    dropdown.addEventListener('click', function(e) { e.stopPropagation(); });
  });
})();
</script>

