{{ 'landing-page.css' | asset_url | stylesheet_tag }}
<script src="{{ 'landing-page.js' | asset_url }}" defer="defer"></script>

<style>
  /* Hide Dawn's native header/announcement bar */
  .header-wrapper,
  .announcement-bar-section { display: none !important; }
</style>

{%- comment -%} ANNOUNCEMENT BAR {%- endcomment -%}
{%- if section.settings.announcement_text != blank -%}
  <div class="taji-announcement-bar" id="taji-announcement-bar-global">
    <p>{{ section.settings.announcement_text | escape }}</p>
  </div>
{%- endif -%}

{%- comment -%} NAVIGATION {%- endcomment -%}
<nav id="taji-main-nav">
  <div class="nav-inner">

    <div class="nav-mobile-left">
      <button class="nav-hamburger" id="taji-nav-hamburger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <a href="{{ routes.search_url }}" class="nav-icon-btn" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/>
        </svg>
      </a>
    </div>

    <a href="{{ section.settings.nav_link_1_url | default: '/' }}" class="nav-logo">
      {%- if section.settings.nav_logo != blank -%}
        <img src="{{ section.settings.nav_logo | image_url: width: 300 }}" alt="{{ shop.name }}" width="120" height="76" />
      {%- else -%}
        <img src="{{ 'taji-logo.png' | asset_url }}" alt="{{ shop.name }}" width="120" height="76" />
      {%- endif -%}
    </a>

    <ul class="nav-links">
      {%- if section.settings.nav_link_1_label != blank -%}
        <li><a href="{{ section.settings.nav_link_1_url | default: '/' }}" {% if request.path == section.settings.nav_link_1_url %}style="color:var(--gold)"{% endif %}>{{ section.settings.nav_link_1_label }}</a></li>
      {%- endif -%}
      {%- if section.settings.nav_link_2_label != blank -%}
        <li><a href="{{ section.settings.nav_link_2_url | default: '#' }}" {% if request.path == section.settings.nav_link_2_url %}style="color:var(--gold)"{% endif %}>{{ section.settings.nav_link_2_label }}</a></li>
      {%- endif -%}
      {%- if section.settings.nav_link_3_label != blank -%}
        <li><a href="{{ section.settings.nav_link_3_url | default: '#' }}" {% if request.path == section.settings.nav_link_3_url %}style="color:var(--gold)"{% endif %}>{{ section.settings.nav_link_3_label }}</a></li>
      {%- endif -%}
      {%- if section.settings.nav_link_4_label != blank -%}
        <li><a href="{{ section.settings.nav_link_4_url | default: '#' }}" {% if request.path == section.settings.nav_link_4_url %}style="color:var(--gold)"{% endif %}>{{ section.settings.nav_link_4_label }}</a></li>
      {%- endif -%}
    </ul>

    <div class="nav-right">
      <a href="{{ routes.search_url }}" class="nav-icon-btn nav-search-desktop" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/>
        </svg>
      </a>
      <div class="nav-icons">
        <a href="{{ routes.account_url }}" class="nav-icon-btn" aria-label="My Account">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
        </a>
        <a href="{{ routes.cart_url }}" class="nav-icon-btn" aria-label="Cart">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
          </svg>
        </a>
      </div>
      <a href="{{ section.settings.nav_shop_btn_url | default: routes.all_products_collection_url }}" class="btn-nav">
        {{- section.settings.nav_shop_btn_text | default: 'Shop Now' -}}
      </a>
    </div>

  </div>
</nav>

{%- comment -%} MOBILE DRAWER {%- endcomment -%}
<div class="nav-drawer" id="taji-nav-drawer" aria-hidden="true">
  <ul class="nav-drawer-links">
    {%- if section.settings.nav_link_1_label != blank -%}
      <li><a href="{{ section.settings.nav_link_1_url | default: '/' }}">{{ section.settings.nav_link_1_label }}</a></li>
    {%- endif -%}
    {%- if section.settings.nav_link_2_label != blank -%}
      <li><a href="{{ section.settings.nav_link_2_url | default: '#' }}">{{ section.settings.nav_link_2_label }}</a></li>
    {%- endif -%}
    {%- if section.settings.nav_link_3_label != blank -%}
      <li><a href="{{ section.settings.nav_link_3_url | default: '#' }}">{{ section.settings.nav_link_3_label }}</a></li>
    {%- endif -%}
    {%- if section.settings.nav_link_4_label != blank -%}
      <li><a href="{{ section.settings.nav_link_4_url | default: '#' }}">{{ section.settings.nav_link_4_label }}</a></li>
    {%- endif -%}
  </ul>
  <div class="nav-drawer-cta">
    <a href="{{ section.settings.nav_shop_btn_url | default: routes.all_products_collection_url }}" class="btn-primary">
      {{- section.settings.nav_shop_btn_text | default: 'Shop Now' -}}
    </a>
  </div>
</div>

<script>
  (function() {
    function hideDawnHeader() {
      document.querySelectorAll('.header-wrapper, .announcement-bar-section, header-drawer').forEach(function(el) {
        el.style.display = 'none';
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', hideDawnHeader);
    } else {
      hideDawnHeader();
    }
  })();
</script>

{% schema %}
{
  "name": "TAJI Header",
  "settings": [
    { "type": "text", "id": "announcement_text", "label": "Announcement text", "default": "Free Shipping on Orders Over $50 · Lebanon Delivery" },
    { "type": "image_picker", "id": "nav_logo", "label": "Logo image" },
    { "type": "text", "id": "nav_shop_btn_text", "label": "Shop button label", "default": "Shop Now" },
    { "type": "url", "id": "nav_shop_btn_url", "label": "Shop button URL" },
    { "type": "text", "id": "nav_link_1_label", "label": "Nav link 1 label", "default": "Home" },
    { "type": "url", "id": "nav_link_1_url", "label": "Nav link 1 URL" },
    { "type": "text", "id": "nav_link_2_label", "label": "Nav link 2 label", "default": "Products" },
    { "type": "url", "id": "nav_link_2_url", "label": "Nav link 2 URL" },
    { "type": "text", "id": "nav_link_3_label", "label": "Nav link 3 label", "default": "About Us" },
    { "type": "url", "id": "nav_link_3_url", "label": "Nav link 3 URL" },
    { "type": "text", "id": "nav_link_4_label", "label": "Nav link 4 label", "default": "Contact" },
    { "type": "url", "id": "nav_link_4_url", "label": "Nav link 4 URL" }
  ]
}
{% endschema %}
